{
  "expo": {
    "name": "BlepPlay",
    "slug": "blep-play",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "blepplay",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#18181b",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.glopblog.blepplay",
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "Audio File",
            "LSHandlerRank": "Default",
            "LSItemContentTypes": [
              "public.mp3",
              "public.mpeg-4-audio",
              "public.audio",
              "com.apple.m4a-audio",
              "com.microsoft.waveform-audio",
              "public.aiff-audio",
              "public.aac-audio",
              "public.flac-audio"
            ]
          }
        ],
        "LSSupportsOpeningDocumentsInPlace": true,
        "UIFileSharingEnabled": true,
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#18181b",
        "foregroundImage": "./assets/images/icon.png",
        "backgroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/icon.png"
      },
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_AUDIO",
        "CAMERA",
        "FOREGROUND_SERVICE",
        "WAKE_LOCK"
      ],
      "predictiveBackGestureEnabled": false,
      "package": "com.glopblog.blepplay",
      "intentFilters": [
        {
          "autoVerify": true,
          "action": "android.intent.action.VIEW",
          "data": [
            {
              "scheme": "content",
              "mimeType": "audio/*"
            },
            {
              "scheme": "file",
              "mimeType": "audio/*"
            }
          ],
          "category": [
            "android.intent.category.DEFAULT",
            "android.intent.category.BROWSABLE"
          ]
        },
        {
          "action": "android.intent.action.VIEW",
          "data": [
            {
              "scheme": "content",
              "host": "*",
              "pathPattern": ".*\\.mp3"
            },
            {
              "scheme": "content",
              "host": "*",
              "pathPattern": ".*\\.m4a"
            },
            {
              "scheme": "content",
              "host": "*",
              "pathPattern": ".*\\.wav"
            },
            {
              "scheme": "content",
              "host": "*",
              "pathPattern": ".*\\.flac"
            },
            {
              "scheme": "content",
              "host": "*",
              "pathPattern": ".*\\.aac"
            },
            {
              "scheme": "file",
              "host": "*",
              "pathPattern": ".*\\.mp3"
            },
            {
              "scheme": "file",
              "host": "*",
              "pathPattern": ".*\\.m4a"
            },
            {
              "scheme": "file",
              "host": "*",
              "pathPattern": ".*\\.wav"
            }
          ],
          "category": [
            "android.intent.category.DEFAULT",
            "android.intent.category.BROWSABLE"
          ]
        },
        {
          "action": "android.intent.action.SEND",
          "data": [
            {
              "mimeType": "audio/*"
            }
          ],
          "category": ["android.intent.category.DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#18181b",
          "resizeMode": "contain",
          "image": "./assets/images/splash.png"
        }
      ],
      [
        "expo-file-system",
        {
          "supportsOpeningDocumentsInPlace": true,
          "enableFileSharing": true
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone.",
          "enableBackgroundPlayback": true,
          "enableBackgroundRecording": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/splash.png",
          "color": "#ffffff",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": false
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "PlayerWidget",
              "label": "Player - Última Música",
              "description": "Mostra a última música tocada",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "previewImage": "./assets/images/icon.png",
              "updatePeriodMillis": 0
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "444fcb6e-bf40-4668-9d79-f754753be4bb"
      }
    }
  }
}
